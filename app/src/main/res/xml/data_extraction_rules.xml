<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include databases -->
        <include domain="database" path="calm_calories.db"/>
        <include domain="database" path="calm_calories.db-shm"/>
        <include domain="database" path="calm_calories.db-wal"/>
    </cloud-backup>
    <device-to-device-transfer>
        <include domain="database" path="calm_calories.db"/>
        <include domain="database" path="calm_calories.db-shm"/>
        <include domain="database" path="calm_calories.db-wal"/>
    </device-to-device-transfer>
</data-extraction-rules>
