<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include databases -->
        <include domain="database" path="calm_calories.db"/>
        <include domain="database" path="calm_calories.db-shm"/>
        <include domain="database" path="calm_calories.db-wal"/>

        <!-- Exclude large models -->
        <exclude domain="external" path="Download/"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm"/>
    </cloud-backup>
    <device-to-device-transfer>
        <include domain="database" path="calm_calories.db"/>
        <include domain="database" path="calm_calories.db-shm"/>
        <include domain="database" path="calm_calories.db-wal"/>

        <exclude domain="external" path="Download/"/>
        <exclude domain="file" path="gemma-4-E2B-it.litertlm"/>
    </device-to-device-transfer>
</data-extraction-rules>
